{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite --host 127.0.0.1",
        "serve": "php artisan serve --host=127.0.0.1 --port=8000",
        "dev:clean": "php artisan optimize:clear && php -r \"if (file_exists('public/hot')) unlink('public/hot');\"",
        "dev:full": "npm run dev:clean && concurrently \"npm run serve\" \"npm run dev\""
    },
    "devDependencies": {
        "@vitejs/plugin-react": "^5.0.0",
        "@tailwindcss/vite": "^4.0.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.0.0",
        "tailwindcss": "^4.0.0",
        "vite": "^8.0.0"
    },
    "dependencies": {
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    }
}
